#########################################################################
# STAMM - INFLUXDB
# Environment configuration template (.env.example)
#
# Copy to `.env` and replace placeholders with real values.
# Do NOT commit `.env` to version control.
#########################################################################

# =====================================================================
# 1) InfluxDB core bootstrap (admin + org + initial bucket)
# =====================================================================

# Public HTTP endpoint (used by other services: Node-RED, Airflow, etc.)
INFLUXDB_URL=http://influxdb:8086

# Admin identity used ONLY for initial setup.
# This user + token are created by DOCKER_INFLUXDB_INIT_* and then reused
# by the bootstrap script to create extra buckets and tokens.
INFLUXDB_ADMIN_USERNAME=admin
INFLUXDB_ADMIN_PASSWORD=admin1234
INFLUXDB_ADMIN_TOKEN=REPLACE_WITH_A_LONG_RANDOM_TOKEN

# Initial bucket required by the official image bootstrap.
# After that, we create the 3 STAMM buckets in a second step.
INFLUXDB_BOOT_BUCKET=bootstrap
BOOT_RETENTION=7d

# =====================================================================
# 2) STAMM buckets & retention policies
# =====================================================================
# Raw sensor data from equipment
RAW_BUCKET=stamm_raw
RAW_RETENTION=90d             # adjust as needed

# Soft-sensor and ML model predictions
PREDICTIONS_BUCKET=stamm_predictions
PREDICTIONS_RETENTION=180d

# Metadata (units, display names, decimals, etc.)
METADATA_BUCKET=stamm_metadata
METADATA_RETENTION=0          # 0 = infinite retention

# =====================================================================
# 3) Token display names (labels used when creating tokens)
# =====================================================================
# Read/Write tokens (programmatic access for STAMM services)
RAW_RW_TOKEN_NAME=stamm_raw_rw
PRED_RW_TOKEN_NAME=stamm_predictions_rw
META_RW_TOKEN_NAME=stamm_metadata_rw

# Optional read-only tokens (set to empty to skip creation)
RAW_RO_TOKEN_NAME=stamm_raw_ro
PRED_RO_TOKEN_NAME=stamm_predictions_ro
META_RO_TOKEN_NAME=stamm_metadata_ro
